---
// Props opcionales para reutilizar esta sección en otras páginas
interface Props {
  title?:    string;
  subtitle?: string;
  cta?:      string;
  href?:     string;
}

const {
  title    = "¿Listo para construir?",
  subtitle = "Despliega tu servidor de alto rendimiento en segundos.",
  cta      = "Desplegar Servidor →",
  href     = "https://billing.arkaniahost.xyz/products/minecraft-server",
} = Astro.props;
---

<section class="py-24 border-y border-white/[0.08] relative z-10">
  <div class="max-w-7xl mx-auto px-6">
    <div class="flex flex-col md:flex-row items-center justify-between gap-8 glass-card p-10 md:p-14 relative overflow-hidden">

      <!-- Luz ambiental decorativa -->
      <div
        class="absolute right-0 top-0 w-64 h-64 bg-brand/10 rounded-full blur-[80px] pointer-events-none"
        aria-hidden="true"
      ></div>

      <div class="text-center md:text-left relative z-10">
        <h2 class="font-display text-3xl md:text-4xl font-bold mb-3 text-white">{title}</h2>
        <p class="text-gray-400 text-lg font-light">{subtitle}</p>
      </div>

      <a
        href={href}
        class="bg-brand hover:bg-[#aa00d4] text-white px-8 py-4 rounded-lg text-sm font-bold transition-all shadow-[0_0_20px_rgba(204,0,255,0.2)] text-center relative z-10 whitespace-nowrap"
      >
        {cta}
      </a>

    </div>
  </div>
</section>
