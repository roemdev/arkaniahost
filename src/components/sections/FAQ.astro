---
import { getCollection } from "astro:content";

const faqs = (await getCollection("faq")).sort(
  (a, b) => a.data.order - b.data.order
);
---

<section id="faq" class="py-24 max-w-3xl mx-auto px-6 border-t border-white/[0.08] relative z-10">
  <h2 class="font-display text-2xl md:text-3xl font-bold tracking-tight mb-10 text-center text-white">
    Respuestas rápidas.
  </h2>

  <div class="space-y-4">
    {faqs.map(({ data: faq }) => (
      <details class="group glass-card overflow-hidden">
        <summary class="flex justify-between items-center font-medium text-white p-6 hover:text-brand transition-colors cursor-pointer outline-none">
          {faq.question}
          <span class="transition-transform duration-300 group-open:rotate-45 text-gray-500 ml-4 flex-shrink-0">
            +
          </span>
        </summary>
        <div class="text-gray-400 text-sm px-6 pb-6 font-light leading-relaxed border-t border-white/5 pt-4 mt-2">
          {faq.answer}
        </div>
      </details>
    ))}
  </div>
</section>

<!-- Accordion: cierra las demás al abrir una -->
<script>
  const allDetails = document.querySelectorAll<HTMLDetailsElement>("#faq details");
  allDetails.forEach((target) => {
    target.addEventListener("click", () => {
      allDetails.forEach((d) => {
        if (d !== target) d.removeAttribute("open");
      });
    });
  });
</script>
