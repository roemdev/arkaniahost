---
import { MARQUEE_FEATURES } from "../../data/navigation";
---

<!--
  Fila de stats estática: cada feature ocupa una columna con ícono grande,
  nombre y un separador vertical entre columnas.
-->
<div class="w-full border-y border-white/[0.08] bg-white/[0.01] relative z-10">
  <div class="max-w-7xl mx-auto grid grid-cols-2 md:grid-cols-4 divide-x divide-white/[0.08]">
    {MARQUEE_FEATURES.map((f) => (
        <div class="flex flex-col items-center justify-center gap-3 py-8 px-6 group">
          <div class="w-10 h-10 rounded-lg bg-brand/10 border border-brand/20 flex items-center justify-center transition-colors group-hover:bg-brand/20">
            <i class={`${f.icon} text-brand text-base`}></i>
          </div>
          <span class="text-sm font-medium text-gray-300 text-center">{f.label}</span>
        </div>
    ))}
  </div>
</div>