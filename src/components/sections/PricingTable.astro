---
import { getCollection } from "astro:content";

const plans = (await getCollection("plans")).sort(
  (a, b) => a.data.order - b.data.order
);
---

<section id="planes" class="py-24 md:py-32 relative z-10">
  <div class="max-w-7xl mx-auto px-6 text-center">

    <h2 class="font-display text-3xl md:text-4xl font-bold tracking-tight mb-4 text-white">
      Planes diseñados para escalar.
    </h2>
    <p class="text-gray-400 text-lg font-light mb-16">
      Transparencia absoluta. Cancela cuando quieras. Espacio ilimitado.
    </p>

    <div class="grid md:grid-cols-2 lg:grid-cols-4 gap-6 items-end text-left">
      {plans.map(({ data: plan }) => (
        <div
          class:list={[
            "flex flex-col js-reveal",
            plan.featured ? "premium-glass-card p-8 h-[105%]" : "glass-card p-8 h-full",
          ]}
        >
          <!-- Badge "Sugerido" -->
          {plan.badge && (
            <div class="absolute -top-3 left-8 bg-brand text-white px-3 py-1 rounded text-[10px] font-bold tracking-wider uppercase">
              {plan.badge}
            </div>
          )}

          <h3
            class:list={[
              "font-display text-lg font-semibold mb-1",
              plan.featured ? "mt-2 text-brand" : "text-white",
            ]}
          >
            {plan.name}
          </h3>

          <p
            class:list={[
              "text-xs mb-6 h-8",
              plan.featured ? "text-gray-300" : "text-gray-500",
            ]}
          >
            {plan.tagline}
          </p>

          <!-- Precio -->
          <div class="mb-8 font-display font-bold text-white">
            <span class:list={["font-bold", plan.featured ? "text-4xl" : "text-3xl"]}>
              ${plan.price.toFixed(2)}
            </span>
            <span class:list={["text-xs ml-1", plan.featured ? "text-gray-400" : "text-gray-500"]}>
              /mes
            </span>
          </div>

          <!-- Features -->
          <div
            class:list={[
              "border-t border-white/[0.08] pt-6 flex-1 text-sm space-y-4",
              plan.featured ? "text-gray-200" : "text-gray-300",
            ]}
          >
            {plan.features.map((feature) => (
              <div class="flex items-center gap-3">
                <i
                  class:list={[
                    "fa-solid fa-check text-[10px]",
                    plan.featured ? "text-brand" : "text-white/40",
                  ]}
                ></i>
                {feature}
              </div>
            ))}
          </div>

          <!-- CTA -->
          <a
            href={plan.paymenterUrl}
            class:list={[
              "mt-8 w-full py-3.5 rounded text-center text-sm font-bold transition-all block",
              plan.featured
                ? "bg-brand hover:bg-[#aa00d4] text-white shadow-[0_0_15px_rgba(204,0,255,0.3)]"
                : "py-3 bg-white/[0.05] hover:bg-white/[0.1] border border-white/10 text-white font-medium",
            ]}
          >
            Empezar ahora &rarr;
          </a>
        </div>
      ))}
    </div>

  </div>
</section>
