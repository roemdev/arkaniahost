---
import { SOLUTION_CARDS } from "../../data/navigation";
---

<section id="solucion" class="py-24 md:py-32 relative z-10">
  <div class="max-w-7xl mx-auto px-6">

    <div class="text-center md:text-left mb-16 max-w-2xl">
      <h2 class="font-display text-3xl md:text-4xl font-bold tracking-tight mb-4 text-white">
        Ingeniería invisible.
      </h2>
      <p class="text-gray-400 text-lg font-light leading-relaxed">
        Diseñamos una plataforma que oculta la complejidad técnica, dejándote únicamente
        con el control absoluto de tu experiencia.
      </p>
    </div>

    <div class="grid md:grid-cols-3 gap-6">
      {SOLUTION_CARDS.map((card) => (
        <div class="glass-card p-8 flex flex-col h-full js-reveal">
          <div class="w-10 h-10 rounded bg-white/[0.05] border border-white/10 flex items-center justify-center mb-6 text-white">
            <i class={card.icon}></i>
          </div>
          <h3 class="font-display text-xl font-semibold mb-3 text-white">{card.title}</h3>
          <p class="text-gray-400 text-sm leading-relaxed font-light">{card.description}</p>
        </div>
      ))}
    </div>

  </div>
</section>
