---
import { WORKFLOW_STEPS } from "../../data/navigation";
---

<section
  id="funcionamiento"
  class="py-24 border-y border-white/[0.08] relative overflow-hidden z-10 bg-[#050505]/50"
>
  <div class="max-w-6xl mx-auto px-6 text-center">
    <h2 class="font-display text-3xl font-bold tracking-tight mb-20 text-white">
      Flujo de trabajo simple
    </h2>

    <div class="grid md:grid-cols-3 gap-12 relative">
      <!-- Línea conectora decorativa (solo desktop) -->
      <div
        class="absolute top-[20px] left-0 w-full h-[1px] bg-white/[0.08] hidden md:block"
        aria-hidden="true"
      ></div>

      {WORKFLOW_STEPS.map((step) => (
        <div class="group relative z-10 js-reveal">
          <div class="w-10 h-10 rounded-full bg-dark border border-white/20 text-white group-hover:border-brand group-hover:text-brand flex items-center justify-center text-sm font-bold mb-6 mx-auto transition-colors duration-300">
            {step.number}
          </div>
          <h3 class="font-display text-lg font-bold text-white mb-2 group-hover:text-brand transition-colors">
            {step.title}
          </h3>
          <p class="text-gray-400 text-sm font-light">{step.description}</p>
        </div>
      ))}
    </div>
  </div>
</section>
